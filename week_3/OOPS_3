import java.util.Random;

// Abstract Class
abstract class Compartment {
    public abstract String notice();
}

// FirstClass Class
class FirstClass extends Compartment {
    public String notice() {
        return "First Class Compartment: Comfortable seating for reserved passengers.";
    }
}

// Ladies Class
class Ladies extends Compartment {
    public String notice() {
        return "Ladies Compartment: Reserved for women passengers only.";
    }
}

// General Class
class General extends Compartment {
    public String notice() {
        return "General Compartment: Open for all passengers.";
    }
}

// Luggage Class
class Luggage extends Compartment {
    public String notice() {
        return "Luggage Compartment: For luggage and goods only.";
    }
}

// Main Class
public class TestCompartment {
    public static void main(String[] args) {

        Compartment[] compartments = new Compartment[10];
        Random rand = new Random();

        // Create 10 random compartments
        for (int i = 0; i < compartments.length; i++) {

            int choice = rand.nextInt(4) + 1; // Random number between 1 and 4

            switch (choice) {
                case 1:
                    compartments[i] = new FirstClass();
                    break;

                case 2:
                    compartments[i] = new Ladies();
                    break;

                case 3:
                    compartments[i] = new General();
                    break;

                case 4:
                    compartments[i] = new Luggage();
                    break;
            }
        }

        // Demonstrating Polymorphism
        System.out.println("Railway Compartments and Notices:\n");

        for (int i = 0; i < compartments.length; i++) {
            System.out.println("Compartment " + (i + 1) + ": "
                    + compartments[i].notice());
        }
    }
}
