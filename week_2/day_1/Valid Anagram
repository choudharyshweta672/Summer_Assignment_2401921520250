class Solution {
public:
    bool isAnagram(string s, string t) {
        if (s.length()!=t.length())
        return 0;
        int counts[26]={0};
        for(int i=0; i<s.length(); i++){
            counts[s[i]-'a']++;
            counts[t[i]-'a']--;


        }
        for(int count : counts){
            if(count!=0){
                return false;

            }
        }
    return true;
    }
};
